{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "#Schema": {
            "const": {}
        },
        "#Schemas": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "additionalProperties": true,
                "$ref": "#/$defs/%23Schema"
            }
        },
        "Time": {
            "type": "string"
        }
    },
    "type": "object",
    "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "$ref": "#/$defs/%23Schema"
    },
    "properties": {
        "Message": {
            "type": "object",
            "properties": {
                "NiceMessage": {
                    "type": "string"
                },
                "NotsoNiceMessage": {
                    "type": "string"
                }
            },
            "required": [
                "NiceMessage",
                "NotsoNiceMessage"
            ]
        },
        "PersonalData": {
            "type": "object",
            "properties": {
                "birthdate": {
                    "$ref": "#/$defs/Time"
                },
                "forename": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "wish": {
                    "type": "string"
                }
            },
            "required": [
                "birthdate",
                "forename",
                "name",
                "wish"
            ]
        },
        "Pet": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "petType": {
                    "type": "string",
                    "enum": [
                        "dog",
                        "cat"
                    ]
                }
            },
            "required": [
                "name",
                "petType"
            ]
        }
    },
    "$ref": "#/$defs/%23Schemas",
    "required": [
        "Message",
        "PersonalData",
        "Pet"
    ]
}
