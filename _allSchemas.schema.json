{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "#TestInput": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string"
                },
                "pet": {
                    "enum": [
                        "dog",
                        "cat"
                    ]
                }
            },
            "required": [
                "name",
                "pet"
            ]
        },
        "#TestOutput": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "message": {
                    "type": "string"
                }
            },
            "required": [
                "message"
            ]
        }
    },
    "type": "object",
    "properties": {
        "TestInput": {
            "$ref": "#/$defs/%23TestInput"
        },
        "TestOutput": {
            "$ref": "#/$defs/%23TestOutput"
        }
    },
    "required": [
        "TestInput",
        "TestOutput"
    ]
}
